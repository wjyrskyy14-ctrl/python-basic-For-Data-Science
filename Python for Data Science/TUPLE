anggota_keluarga = ('Rasky', 'steve', 'jhon', 'Vira', 'Miva', 'Riska', 'Ayah', 'Ibu')

brother1, brother2, brother3, sister1, sister2, sister3, father, mother = anggota_keluarga # unpacking tuple anggota_keluarga ke dalam variabel yang sesuai

#membuat tupel buah-buahan, sayuran dan produk hewani
buah = ('banana', 'orange', 'mango')
sayur = ('bayam', 'kangkung', 'selada')
daging = ('ayam', 'sapi', 'kambing')

food_stuff_tp = buah + sayur + daging #menggabungkan ketiga tupel dan menetapkan ke variabel food_stuff_tp
print(food_stuff_tp, '\n')

#mengubah tuple menjadi list
food_stuff_lt = list(food_stuff_tp)

# memotong item tengah dari food_stuff_tp
middle_index = len(food_stuff_tp) // 2
print(food_stuff_tp[middle_index], '\n') #mengambil item tengah dari food_stuff_tp

#menampilkan tiga item pertama dan tiga item terakhir dari food_stuff_lt
tiga_item_pertama = food_stuff_tp[:3]
print(tiga_item_pertama, '\n') #output: ('banana', 'orange', 'mango')
tiga_item_terakhir = food_stuff_tp[-3:]
print(tiga_item_terakhir, '\n') #output: ('ayam', 'sapi', 'kambing')

#menghapus tuple food_stuff_tp sepenuhnya
del food_stuff_tp
print(food_stuff_tp) #error karena sudah dihapus

