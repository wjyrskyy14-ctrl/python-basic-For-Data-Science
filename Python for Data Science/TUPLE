# tips  : tuple → list → edit → tuple lagi

fruits = ('banana','orange','mango')

fruits = list(fruits)
fruits[0] = 'apple'
fruits = tuple(fruits)

print(fruits, '\n') #apple, orange, mango

#Mengecek Item di Tuple
print('banana' in fruits, '\n') #false

